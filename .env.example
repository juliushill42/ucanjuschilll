# =============================================================================
# JUSCHILL PLATFORM — Environment Variables
# Copy to .env and fill in all values before running
# =============================================================================

# PostgreSQL
POSTGRES_USER=juschill
POSTGRES_PASSWORD=change_this_strong_password_123
POSTGRES_DB=juschill_db

# Redis
REDIS_PASSWORD=change_this_redis_password_456

# JWT (generate: openssl rand -hex 64)
JWT_SECRET=change_this_jwt_secret_minimum_64_chars_long_replace_me_now_seriously

# Storage
STORAGE_PATH=/data/uploads

# URLs
NEXT_PUBLIC_API_URL=http://localhost/api
HLS_BASE_URL=http://localhost/hls
RTMP_URL=rtmp://localhost/live

# AI Services
# Google Cloud / Vertex AI
GCP_PROJECT_ID=gen-lang-client-0695165560
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
